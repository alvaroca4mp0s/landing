# ── RedLocal — variables de entorno ──
# Copia a .env.local (desarrollo) o configura en el servidor (producción).
# NUNCA comitear valores reales. .env* está en .gitignore.

# Twenty CRM (integración del formulario comercial).
# Si TWENTY_API_KEY no está definida, el lead se guarda en disco (fallback)
# y el usuario recibe confirmación igual: nunca se pierde un lead.
TWENTY_API_URL=https://crm.redlocal.cl/rest
TWENTY_API_KEY=

# Directorio donde se persisten los leads cuando el CRM no está disponible.
# Debe existir y ser escribible por el proceso Node. Fuera del webroot.
LEADS_DIR=./data/leads
